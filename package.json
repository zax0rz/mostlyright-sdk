{
  "name": "tradewinds-ts-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for @tradewinds/* TypeScript SDK packages. Not published.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "codegen": "pnpm -r run codegen",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r run typecheck",
    "size": "size-limit",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm -r run build && changeset publish"
  },
  "size-limit": [
    {
      "name": "@tradewinds/core (W1 surface, gzipped ESM)",
      "path": "packages-ts/core/dist/index.mjs",
      "limit": "25 KB"
    },
    {
      "name": "@tradewinds/weather (W1: AWC+CLI only, gzipped ESM)",
      "path": "packages-ts/weather/dist/index.mjs",
      "limit": "20 KB"
    },
    {
      "name": "@tradewinds/markets (W1: Kalshi NHIGH/NLOW, gzipped ESM)",
      "path": "packages-ts/markets/dist/index.mjs",
      "limit": "15 KB"
    },
    {
      "name": "tradewinds meta (W1 subset, gzipped ESM)",
      "path": "packages-ts/meta/dist/index.mjs",
      "limit": "30 KB"
    }
  ],
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "2.27.10",
    "@size-limit/preset-small-lib": "11.1.6",
    "@vitest/coverage-v8": "2.1.9",
    "lefthook": "1.7.22",
    "size-limit": "11.1.6",
    "tsup": "8.3.5",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  }
}
