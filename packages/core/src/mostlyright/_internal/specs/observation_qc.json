{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mostlyright.dev/schemas/observation_qc.json",
  "title": "Observation QC Sidecar",
  "description": "Phase 2.1 forward-compat declaration; QC engine + writer hooks land in Phase 3.4. One row per QC rule firing per (station_code, observed_at, source) ledger key. 13 fields per the Phase 2.1 spec: ledger lineage keys + QC system identifiers + detector metadata payload.",
  "type": "object",
  "required": ["station_code", "observed_at", "source", "qc_system", "qc_version", "rule_id", "field", "flag"],
  "additionalProperties": false,
  "properties": {
    "station_code": {"type": "string", "pattern": "^[A-Z]{3,4}$"},
    "observed_at": {"type": "string", "format": "date-time"},
    "observation_kind": {"type": ["string", "null"], "enum": ["METAR", "SPECI", null]},
    "source": {"type": "string", "enum": ["awc", "iem", "ghcnh", "ncei"]},
    "parser_name": {"type": ["string", "null"]},
    "as_of_time": {"type": ["string", "null"], "format": "date-time"},
    "ingestion_id": {"type": ["string", "null"]},
    "qc_system": {"type": "string"},
    "qc_version": {"type": "string"},
    "rule_id": {"type": "string"},
    "field": {"type": "string"},
    "flag": {"type": "string", "enum": ["clean", "flagged", "suspect"]},
    "detector_metadata": {"type": ["object", "string", "null"]}
  }
}
