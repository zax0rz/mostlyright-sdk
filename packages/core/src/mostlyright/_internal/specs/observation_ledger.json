{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mostlyright.dev/schemas/observation_ledger.json",
  "title": "Silver-tier Observation Ledger (rows-per-source)",
  "description": "Phase 2.1 silver-tier ledger schema (LINEAGE-01..05). Carries one row per (station_code, observed_at, source). Multiple rows per (station_code, observed_at) are valid (one per contributing source: AWC, IEM, GHCNh). Read-time ObservationMergePolicy.apply() materializes single-row-per-key gold for Mode-1 parity callers. Extends v0.14.1 observation.json with 9 lineage fields (all nullable for backward-compat). Source enum extends to reserve 'ncei' per D-2.1-09 — never written in v0.1.0.",
  "type": "object",
  "required": ["station_code", "observed_at", "observation_type", "source"],
  "additionalProperties": false,
  "properties": {
    "station_code": {"type": "string", "pattern": "^[A-Z]{3,4}$"},
    "observed_at": {"type": "string", "format": "date-time"},
    "observation_type": {"type": "string", "enum": ["METAR", "SPECI"]},
    "source": {"type": "string", "enum": ["awc", "iem", "ghcnh", "ncei"]},
    "temp_c": {"type": ["number", "null"]},
    "dewpoint_c": {"type": ["number", "null"]},
    "temp_f": {"type": ["number", "null"]},
    "dewpoint_f": {"type": ["number", "null"]},
    "wind_dir_degrees": {"type": ["integer", "null"]},
    "wind_speed_kt": {"type": ["integer", "null"]},
    "wind_gust_kt": {"type": ["integer", "null"]},
    "altimeter_inhg": {"type": ["number", "null"]},
    "sea_level_pressure_mb": {"type": ["number", "null"]},
    "sky_cover_1": {"type": ["string", "null"]},
    "sky_base_1_ft": {"type": ["integer", "null"]},
    "sky_cover_2": {"type": ["string", "null"]},
    "sky_base_2_ft": {"type": ["integer", "null"]},
    "sky_cover_3": {"type": ["string", "null"]},
    "sky_base_3_ft": {"type": ["integer", "null"]},
    "sky_cover_4": {"type": ["string", "null"]},
    "sky_base_4_ft": {"type": ["integer", "null"]},
    "visibility_miles": {"type": ["number", "null"]},
    "weather_codes": {"type": ["string", "null"]},
    "precip_1hr_inches": {"type": ["number", "null"]},
    "peak_wind_gust_kt": {"type": ["integer", "null"]},
    "peak_wind_dir": {"type": ["integer", "null"]},
    "peak_wind_time": {"type": ["string", "null"]},
    "snow_depth_inches": {"type": ["number", "null"]},
    "qc_field": {"type": ["integer", "null"]},
    "raw_metar": {"type": ["string", "null"]},
    "parser_name": {"type": ["string", "null"], "enum": ["mostlyright_v1", "iem", "ncei", "ghcnh", null]},
    "parser_version": {"type": ["string", "null"]},
    "ingestion_id": {"type": ["string", "null"]},
    "as_of_time": {"type": ["string", "null"], "format": "date-time"},
    "source_received_at": {"type": ["string", "null"]},
    "qc_status": {"type": ["string", "null"], "enum": ["clean", "flagged", "suspect", null]},
    "observation_kind": {"type": ["string", "null"], "enum": ["METAR", "SPECI", null]},
    "provenance": {"type": ["string", "null"], "enum": ["legacy", "reingested", null]},
    "observation_quality": {"type": ["string", "null"], "enum": ["clean", "flagged", "suspect", null]}
  }
}
