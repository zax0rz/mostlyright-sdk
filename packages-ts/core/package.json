{
  "name": "@tradewinds/core",
  "version": "0.0.0",
  "description": "Core types, schemas, and primitives for the tradewinds TypeScript SDK (placeholder scaffold; implementation lands in TS-W1+).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./internal/bounds": {
      "types": "./dist/internal/bounds.d.ts",
      "import": "./dist/internal/bounds.mjs",
      "require": "./dist/internal/bounds.cjs"
    },
    "./internal/convert": {
      "types": "./dist/internal/convert.d.ts",
      "import": "./dist/internal/convert.mjs",
      "require": "./dist/internal/convert.cjs"
    },
    "./internal/merge": {
      "types": "./dist/internal/merge/index.d.ts",
      "import": "./dist/internal/merge/index.mjs",
      "require": "./dist/internal/merge/index.cjs"
    },
    "./internal/pairs": {
      "types": "./dist/internal/pairs.d.ts",
      "import": "./dist/internal/pairs.mjs",
      "require": "./dist/internal/pairs.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "prebuild": "pnpm --filter @tradewinds/codegen run codegen",
    "build": "tsup",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "codegen": "echo \"@tradewinds/core — no codegen step at this layer (consumes from @tradewinds/codegen output)\""
  },
  "devDependencies": {
    "fast-check": "3.23.2",
    "tsup": "8.3.5",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
