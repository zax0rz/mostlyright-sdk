{
  "name": "@tradewinds/core",
  "version": "0.0.0",
  "description": "Core types, schemas, and primitives for the tradewinds TypeScript SDK (placeholder scaffold; implementation lands in TS-W1+).",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./internal/bounds": {
      "types": "./dist/internal/bounds.d.ts",
      "import": "./dist/internal/bounds.mjs",
      "require": "./dist/internal/bounds.cjs"
    },
    "./internal/convert": {
      "types": "./dist/internal/convert.d.ts",
      "import": "./dist/internal/convert.mjs",
      "require": "./dist/internal/convert.cjs"
    },
    "./internal/merge": {
      "types": "./dist/internal/merge/index.d.ts",
      "import": "./dist/internal/merge/index.mjs",
      "require": "./dist/internal/merge/index.cjs"
    },
    "./internal/pairs": {
      "types": "./dist/internal/pairs.d.ts",
      "import": "./dist/internal/pairs.mjs",
      "require": "./dist/internal/pairs.cjs"
    },
    "./temporal": {
      "types": "./dist/temporal/index.d.ts",
      "import": "./dist/temporal/index.mjs",
      "require": "./dist/temporal/index.cjs"
    },
    "./formats": {
      "types": "./dist/formats/index.d.ts",
      "import": "./dist/formats/index.mjs",
      "require": "./dist/formats/index.cjs"
    },
    "./internal/cache": {
      "types": "./dist/internal/cache/index.d.ts",
      "import": "./dist/internal/cache/index.mjs",
      "require": "./dist/internal/cache/index.cjs"
    },
    "./internal/cache/fs": {
      "types": "./dist/internal/cache/fs.d.ts",
      "import": "./dist/internal/cache/fs.mjs",
      "require": "./dist/internal/cache/fs.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "prebuild": "pnpm --filter @tradewinds/codegen run codegen",
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "codegen": "echo \"@tradewinds/core — no codegen step at this layer (consumes from @tradewinds/codegen output)\""
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/proper-lockfile": "^4.1.4",
    "@vitest/coverage-v8": "2.1.9",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "3.23.2",
    "jsdom": "^25.0.1",
    "tsup": "8.3.5",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "proper-lockfile": "^4.1.2"
  }
}
