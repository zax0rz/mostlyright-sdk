{
  "name": "@mostlyrightmd/core",
  "version": "1.5.0",
  "description": "TypeScript SDK core for quants, ML pipelines, and AI agents: types, schemas, validators, temporal-safety primitives, and the research() join over weather data + prediction-market settlements. Local-first, no hosted backend.",
  "keywords": [
    "weather",
    "weather-data",
    "prediction-markets",
    "kalshi",
    "polymarket",
    "machine-learning",
    "ml-training",
    "ai-agents",
    "backtesting",
    "quant-research",
    "time-series",
    "schema-versioned",
    "json-schema",
    "local-first",
    "typescript",
    "sdk"
  ],
  "license": "MIT",
  "homepage": "https://mostlyright.md/docs/sdk/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mostlyrightmd/mostlyright-sdk.git",
    "directory": "packages-ts/core"
  },
  "bugs": {
    "url": "https://github.com/mostlyrightmd/mostlyright-sdk/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./internal/bounds": {
      "types": "./dist/internal/bounds.d.ts",
      "import": "./dist/internal/bounds.mjs",
      "require": "./dist/internal/bounds.cjs"
    },
    "./internal/convert": {
      "types": "./dist/internal/convert.d.ts",
      "import": "./dist/internal/convert.mjs",
      "require": "./dist/internal/convert.cjs"
    },
    "./internal/merge": {
      "types": "./dist/internal/merge/index.d.ts",
      "import": "./dist/internal/merge/index.mjs",
      "require": "./dist/internal/merge/index.cjs"
    },
    "./internal/pairs": {
      "types": "./dist/internal/pairs.d.ts",
      "import": "./dist/internal/pairs.mjs",
      "require": "./dist/internal/pairs.cjs"
    },
    "./temporal": {
      "types": "./dist/temporal/index.d.ts",
      "import": "./dist/temporal/index.mjs",
      "require": "./dist/temporal/index.cjs"
    },
    "./formats": {
      "types": "./dist/formats/index.d.ts",
      "import": "./dist/formats/index.mjs",
      "require": "./dist/formats/index.cjs"
    },
    "./transforms": {
      "types": "./dist/transforms/index.d.ts",
      "import": "./dist/transforms/index.mjs",
      "require": "./dist/transforms/index.cjs"
    },
    "./qc": {
      "types": "./dist/qc/index.d.ts",
      "import": "./dist/qc/index.mjs",
      "require": "./dist/qc/index.cjs"
    },
    "./validator": {
      "types": "./dist/validator.d.ts",
      "import": "./dist/validator.mjs",
      "require": "./dist/validator.cjs"
    },
    "./internal/cache": {
      "node": {
        "types": "./dist/internal/cache/index.d.ts",
        "import": "./dist/internal/cache/index.mjs",
        "require": "./dist/internal/cache/index.cjs"
      },
      "default": {
        "types": "./dist/internal/cache/index.browser.d.ts",
        "import": "./dist/internal/cache/index.browser.mjs",
        "require": "./dist/internal/cache/index.browser.cjs"
      }
    },
    "./internal/cache/fs": {
      "types": "./dist/internal/cache/fs.d.ts",
      "import": "./dist/internal/cache/fs.mjs",
      "require": "./dist/internal/cache/fs.cjs"
    },
    "./discovery": {
      "types": "./dist/discovery/index.d.ts",
      "import": "./dist/discovery/index.mjs",
      "require": "./dist/discovery/index.cjs"
    },
    "./preprocessing": {
      "types": "./dist/preprocessing/index.d.ts",
      "import": "./dist/preprocessing/index.mjs",
      "require": "./dist/preprocessing/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "prebuild": "pnpm --filter @mostlyrightmd/codegen run codegen",
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "codegen": "echo \"@mostlyrightmd/core \u2014 no codegen step at this layer (consumes from @mostlyrightmd/codegen output)\""
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/proper-lockfile": "^4.1.4",
    "@vitest/coverage-v8": "2.1.9",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "3.23.2",
    "jsdom": "^25.0.1",
    "tsup": "8.3.5",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "proper-lockfile": "^4.1.2"
  }
}
