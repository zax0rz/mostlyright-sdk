{
  "name": "@mostlyright/weather",
  "version": "0.0.0",
  "description": "Weather fetchers and parsers (AWC, IEM ASOS, IEM CLI, GHCNh) for the mostlyright TypeScript SDK (placeholder scaffold; implementation lands in TS-W1+).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./live": {
      "types": "./dist/live/index.d.ts",
      "import": "./dist/live/index.mjs",
      "require": "./dist/live/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "prebuild": "pnpm --filter @mostlyright/codegen run codegen",
    "build": "tsup",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "codegen": "echo \"@mostlyright/weather — no codegen step at this layer\""
  },
  "peerDependencies": {
    "@mostlyright/core": "^0.0.0"
  },
  "devDependencies": {
    "@mostlyright/core": "workspace:*",
    "tsup": "8.3.5",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
